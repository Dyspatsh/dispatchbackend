# Database connection URL
# Format: postgres://username:password@localhost/database_name
DATABASE_URL=postgres://dispatch:your_password_here@localhost/dispatch

# JWT Secret for authentication tokens (generate a strong random string)
# Generate one using: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_characters

# Server port (default: 3000)
SERVER_PORT=3000
