# Database Configuration
DATABASE_URL=postgres://username:password@localhost/dispatch

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://localhost,https://yourdomain.com,http://localhost:3000

# Storage Configuration
STORAGE_PATH=/opt/dispatch/storage/files

# File Upload Limits
MAX_FILE_SIZE_GB=10
